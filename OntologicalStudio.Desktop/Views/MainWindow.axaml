<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
        xmlns:views="using:OntologicalStudio.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="OntologicalStudio.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ontological Studio"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#1f1f23" Padding="16,10">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Ontological Studio" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock Text="Ontology-Augmented Reasoning System" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="1" Margin="8">
            <TabItem Header="Universes">
                <views:UniversesView DataContext="{Binding Universes}"/>
            </TabItem>
            <TabItem Header="Universe Canvas">
                <views:UniverseCanvasView DataContext="{Binding UniverseCanvas}"/>
            </TabItem>
            <TabItem Header="Entities">
                <views:EntitiesView DataContext="{Binding Entities}"/>
            </TabItem>
            <TabItem Header="Relationships">
                <views:RelationshipsView DataContext="{Binding Relationships}"/>
            </TabItem>
            <TabItem Header="Scenarios">
                <views:ScenariosView DataContext="{Binding Scenarios}"/>
            </TabItem>
            <TabItem Header="Prompt Preview">
                <views:PromptPreviewView DataContext="{Binding Prompt}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
