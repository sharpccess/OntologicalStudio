<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
        xmlns:views="using:OntologicalStudio.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="OntologicalStudio.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ontological Studio"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,*">
        <Border Grid.Row="0" Background="#1f1f23" Padding="16,10">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding AppTitle}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AppSubtitle}" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="{Binding LanguageLabel}" VerticalAlignment="Center" Opacity="0.75"/>
                    <ComboBox Width="90"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedValueBinding="{Binding Code}"
                              SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="8" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="{Binding UniversesTabHeader}">
                <views:UniversesView DataContext="{Binding Universes}"/>
            </TabItem>
            <TabItem Header="{Binding CanvasTabHeader}">
                <views:UniverseCanvasView DataContext="{Binding UniverseCanvas}"/>
            </TabItem>
            <TabItem Header="{Binding EntitiesTabHeader}">
                <views:EntitiesView DataContext="{Binding Entities}"/>
            </TabItem>
            <TabItem Header="{Binding RelationshipsTabHeader}">
                <views:RelationshipsView DataContext="{Binding Relationships}"/>
            </TabItem>
            <TabItem Header="{Binding ScenariosTabHeader}">
                <views:ScenariosView DataContext="{Binding Scenarios}"/>
            </TabItem>
            <TabItem Header="{Binding PromptPreviewTabHeader}">
                <views:PromptPreviewView DataContext="{Binding Prompt}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
