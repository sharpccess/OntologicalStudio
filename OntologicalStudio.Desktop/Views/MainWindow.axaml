<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
        xmlns:views="using:OntologicalStudio.Desktop.Views"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="OntologicalStudio.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="Ontological Studio"
        Width="1200" Height="800"
        WindowStartupLocation="CenterScreen">

    <Grid RowDefinitions="Auto,Auto,*">
        <Border Grid.Row="0" Background="#1f1f23" Padding="16,10">
            <Grid ColumnDefinitions="*,Auto" VerticalAlignment="Center">
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="{Binding AppTitle}" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding AppSubtitle}" FontSize="12" Opacity="0.6" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                    <Button Content="{DynamicResource ai.settings.toggle}"
                            Command="{Binding ToggleAiSettingsCommand}"/>
                    <TextBlock Text="{Binding LanguageLabel}" VerticalAlignment="Center" Opacity="0.75"/>
                    <ComboBox Width="90"
                              ItemsSource="{Binding AvailableLanguages}"
                              SelectedValueBinding="{Binding Code}"
                              SelectedValue="{Binding SelectedLanguageCode, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Label}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Padding="12,10"
                Margin="8,0,8,0"
                Background="#17181d"
                BorderBrush="#333"
                BorderThickness="1"
                CornerRadius="4"
                IsVisible="{Binding IsAiSettingsVisible}">
            <StackPanel Spacing="8" DataContext="{Binding AiSettings}">
                <TextBlock Text="{DynamicResource ai.settings.title}" FontWeight="SemiBold"/>
                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource ai.settings.provider}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <ComboBox Grid.Row="0" Grid.Column="1"
                              Margin="0,0,0,6"
                              ItemsSource="{Binding Providers}"
                              SelectedItem="{Binding SelectedProvider, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding DisplayName}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource ai.settings.endpoint}" VerticalAlignment="Center"/>
                    <TextBox Grid.Row="1" Grid.Column="1"
                             Margin="0,0,0,6"
                             Text="{Binding OllamaEndpoint, Mode=TwoWay}"
                             Watermark="https://ollama.com/api"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource ai.settings.model}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="2" Grid.Column="1"
                             Margin="0,0,0,6"
                             Text="{Binding OllamaModel, Mode=TwoWay}"
                             Watermark="gpt-oss:120b"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource ai.settings.apiKey}" VerticalAlignment="Center" Margin="0,0,8,6"/>
                    <TextBox Grid.Row="3" Grid.Column="1"
                             Margin="0,0,0,6"
                             Text="{Binding OllamaApiKey, Mode=TwoWay}"/>

                    <TextBlock Grid.Row="4" Grid.Column="1"
                               Text="{Binding StatusMessage}"
                               Opacity="0.7"
                               TextWrapping="Wrap"/>
                </Grid>
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <Button Content="{DynamicResource ai.settings.save}"
                            Command="{Binding SaveCommand}"/>
                    <Button Content="{DynamicResource ai.settings.clear}"
                            Command="{Binding ClearCommand}"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <TabControl Grid.Row="2" Margin="8" SelectedIndex="{Binding SelectedTabIndex, Mode=TwoWay}">
            <TabItem Header="{Binding UniversesTabHeader}">
                <views:UniversesView DataContext="{Binding Universes}"/>
            </TabItem>
            <TabItem Header="{Binding CanvasTabHeader}" IsEnabled="{Binding HasActiveUniverse}">
                <views:UniverseCanvasView DataContext="{Binding UniverseCanvas}"/>
            </TabItem>
            <TabItem Header="{Binding EntitiesTabHeader}" IsEnabled="{Binding HasActiveUniverse}">
                <views:EntitiesView DataContext="{Binding Entities}"/>
            </TabItem>
            <TabItem Header="{Binding RelationshipsTabHeader}" IsEnabled="{Binding HasActiveUniverse}">
                <views:RelationshipsView DataContext="{Binding Relationships}"/>
            </TabItem>
            <TabItem Header="{Binding ScenariosTabHeader}" IsEnabled="{Binding HasActiveUniverse}">
                <views:ScenariosView DataContext="{Binding Scenarios}"/>
            </TabItem>
            <TabItem Header="{Binding LibraryTabHeader}">
                <views:LibraryView DataContext="{Binding Library}"/>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
