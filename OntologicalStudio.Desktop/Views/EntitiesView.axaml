<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             xmlns:m="using:OntologicalStudio.Core.Models"
             x:Class="OntologicalStudio.Desktop.Views.EntitiesView"
             x:DataType="vm:EntitiesViewModel">
    <Grid ColumnDefinitions="2*,Auto,3*" Margin="8">
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
            <DockPanel>
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource entities.title}" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedEntity, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Entity">
                            <StackPanel>
                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding EntityType.DisplayName}" Opacity="0.6" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      Background="#2d3742"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource entities.create}" FontWeight="Bold"/>
                    <TextBox Watermark="{DynamicResource entities.name}" Text="{Binding NewName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" IsEnabled="{Binding HasSelectedUniverse}"/>
                    <TextBox Watermark="{DynamicResource entities.description}" Text="{Binding NewDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" Height="80" IsEnabled="{Binding HasSelectedUniverse}"/>
                    <TextBox Watermark="{DynamicResource entities.type}"
                             Text="{Binding NewEntityTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding HasSelectedUniverse}"/>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{DynamicResource entities.create}" Command="{Binding CreateCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                        <Button Content="{DynamicResource entities.deleteSelected}" Command="{Binding DeleteCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11"/>

                    <Separator Margin="0,8"/>
                    <TextBlock Text="{DynamicResource entities.selected}" FontWeight="Bold"/>
                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto,Auto">
                        <TextBlock Grid.Row="0" Grid.Column="0" Text="{DynamicResource entities.name}" Opacity="0.7"/>
                        <TextBlock Grid.Row="0" Grid.Column="1" Text="{Binding SelectedEntity.Name}"/>
                        <TextBlock Grid.Row="1" Grid.Column="0" Text="{DynamicResource entities.type}" Opacity="0.7"/>
                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedEntity.EntityType.DisplayName}"/>
                        <TextBlock Grid.Row="2" Grid.Column="0" Text="{DynamicResource entities.description}" Opacity="0.7"/>
                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding SelectedEntity.Description}" TextWrapping="Wrap"/>
                        <TextBlock Grid.Row="3" Grid.Column="0" Text="{DynamicResource entities.notes}" Opacity="0.7"/>
                        <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding SelectedEntity.Notes}" TextWrapping="Wrap"/>
                    </Grid>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
