<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             xmlns:m="using:OntologicalStudio.Core.Models"
             x:Class="OntologicalStudio.Desktop.Views.RelationshipsView"
             x:DataType="vm:RelationshipsViewModel">
    <Grid ColumnDefinitions="3*,2*" Margin="8">
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
            <DockPanel>
                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="0,0,0,6">
                    <TextBlock Text="{DynamicResource relationships.title}" FontWeight="Bold" VerticalAlignment="Center"/>
                    <Button Content="{DynamicResource relationships.refresh}" Command="{Binding RefreshCommand}"/>
                </StackPanel>
                <ListBox ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedRelationship, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="vm:RelationshipRow">
                            <StackPanel>
                                <TextBlock Text="{Binding Display}" FontFamily="Consolas, Menlo, monospace"/>
                                <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="12">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource relationships.readonlyTitle}" FontWeight="Bold"/>
                    <TextBlock Text="{DynamicResource relationships.readonlyHint}" TextWrapping="Wrap" Opacity="0.7"/>
                    <Separator Margin="0,6"/>
                    <TextBlock Text="{DynamicResource relationships.selected}" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedRelationship.Display}" FontFamily="Consolas, Menlo, monospace" TextWrapping="Wrap"/>
                    <TextBlock Text="{Binding SelectedRelationship.Description}" TextWrapping="Wrap" Opacity="0.7"/>
                    <Button Content="{DynamicResource relationships.deleteSelected}" Command="{Binding DeleteCommand}"/>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11"/>
                </StackPanel>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
