<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             xmlns:m="using:OntologicalStudio.Core.Models"
             x:Class="OntologicalStudio.Desktop.Views.PromptPreviewView"
             x:DataType="vm:PromptPreviewViewModel">
    <Grid RowDefinitions="Auto,*,Auto" Margin="8">
        <Border Grid.Row="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,0,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock Text="{DynamicResource prompt.scenario}" VerticalAlignment="Center"/>
                <ComboBox ItemsSource="{Binding Scenarios}"
                          SelectedItem="{Binding SelectedScenario, Mode=TwoWay}"
                          MinWidth="280">
                    <ComboBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Scenario">
                            <TextBlock Text="{Binding Title}"/>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>
                <Button Content="{DynamicResource prompt.generate}" Command="{Binding GenerateCommand}"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4">
            <TextBox Text="{Binding PromptText, Mode=OneWay}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     FontFamily="Consolas, Menlo, monospace"
                     FontSize="12"
                     VerticalAlignment="Stretch"
                     HorizontalAlignment="Stretch"
                     Background="Transparent"
                     BorderThickness="0"
                     Padding="10"/>
        </Border>

        <TextBlock Grid.Row="2" Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11" Margin="2,6,0,0"/>
    </Grid>
</UserControl>
