<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             xmlns:m="using:OntologicalStudio.Core.Models"
             x:Class="OntologicalStudio.Desktop.Views.ScenariosView"
             x:DataType="vm:ScenariosViewModel">
    <Grid ColumnDefinitions="2*,2*,3*" Margin="8">

        <!-- Column 1: Scenarios list & create -->
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0">
            <Grid RowDefinitions="Auto,*,Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Row="0" Text="{DynamicResource scenarios.title}" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedScenario, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Scenario">
                            <StackPanel>
                                <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding Description}" Opacity="0.6" FontSize="11" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <GridSplitter Grid.Row="2"
                              Height="8"
                              Background="#2d3742"
                              ResizeDirection="Rows"
                              ShowsPreview="True"
                              Margin="0,8,0,8"/>
                <TextBox Grid.Row="3"
                         Watermark="{DynamicResource scenarios.fieldTitle}"
                         Text="{Binding NewTitle, Mode=TwoWay}"/>
                <GridSplitter Grid.Row="4"
                              Height="8"
                              Background="#2d3742"
                              ResizeDirection="Rows"
                              ShowsPreview="True"
                              Margin="0,8,0,8"/>
                <TextBox Grid.Row="5"
                         Watermark="{DynamicResource scenarios.fieldDescription}"
                         Text="{Binding NewDescription, Mode=TwoWay}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         MinHeight="80"/>
                <StackPanel Grid.Row="6" Spacing="6" Margin="0,8,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource scenarios.create}" Command="{Binding CreateCommand}"/>
                        <Button Content="{DynamicResource scenarios.delete}" Command="{Binding DeleteCommand}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Column 2: Solutions list & run -->
        <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8" Margin="0,0,8,0"
                DataContext="{Binding Solutions}"
                x:DataType="vm:SolutionsViewModel">
            <Grid RowDefinitions="Auto,*,Auto,*,Auto,Auto">
                <TextBlock Grid.Row="0" Text="{DynamicResource scenarios.solutions}" FontWeight="Bold" Margin="0,0,0,6"/>
                <ListBox Grid.Row="1"
                         ItemsSource="{Binding Items}"
                         SelectedItem="{Binding SelectedSolution, Mode=TwoWay}">
                    <ListBox.ItemTemplate>
                        <DataTemplate x:DataType="m:Solution">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold"/>
                                    <Border Background="#2a4f6e" CornerRadius="3" Padding="4,1">
                                        <TextBlock Text="{Binding Status}" FontSize="10"/>
                                    </Border>
                                </StackPanel>
                                <TextBlock Text="{Binding ProviderUsed}" Opacity="0.6" FontSize="11"/>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <GridSplitter Grid.Row="2"
                              Height="8"
                              Background="#2d3742"
                              ResizeDirection="Rows"
                              ShowsPreview="True"
                              Margin="0,8,0,8"/>
                <StackPanel Grid.Row="3" Spacing="8">
                    <ComboBox ItemsSource="{Binding ResolutionStyles}"
                              SelectedItem="{Binding SelectedResolutionStyle, Mode=TwoWay}"/>
                    <TextBox Watermark="{DynamicResource scenarios.extraInstructions}"
                             Text="{Binding ExtraInstructions, Mode=TwoWay}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             MinHeight="96"/>
                </StackPanel>
                <Border Grid.Row="4"
                        Margin="0,8,0,0"
                        Padding="8"
                        Background="#1A2028"
                        BorderBrush="#333"
                        BorderThickness="1"
                        CornerRadius="4">
                    <Grid ColumnDefinitions="Auto,Auto,Auto,*" RowDefinitions="Auto,Auto">
                        <Button Grid.Row="0" Grid.Column="0"
                                Margin="0,0,8,0"
                                Content="{DynamicResource scenarios.run}"
                                Command="{Binding RunCommand}"
                                IsEnabled="{Binding !IsRunning}"/>
                        <Button Grid.Row="0" Grid.Column="1"
                                Margin="0,0,8,0"
                                Content="{DynamicResource scenarios.markFinal}"
                                Command="{Binding MarkFinalCommand}"/>
                        <Button Grid.Row="0" Grid.Column="2"
                                Margin="0,0,8,0"
                                Content="{DynamicResource scenarios.delete}"
                                Command="{Binding DeleteCommand}"/>
                        <TextBlock Grid.Row="1"
                                   Margin="0,8,0,0"
                                   Grid.ColumnSpan="4"
                                   Text="{Binding StatusMessage}"
                                   Opacity="0.7"
                                   FontSize="11"
                                   TextWrapping="Wrap"/>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Column 3: Selected solution detail -->
        <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="8"
                DataContext="{Binding Solutions}"
                x:DataType="vm:SolutionsViewModel">
            <Grid RowDefinitions="Auto,*">
                <StackPanel Grid.Row="0" Spacing="4">
                    <TextBlock Text="{Binding SelectedSolution.Title}" FontWeight="Bold" FontSize="14"/>
                    <TextBlock Text="{Binding SelectedSolution.ProviderUsed}" Opacity="0.7" FontSize="11"/>
                    <Separator Margin="0,4"/>
                </StackPanel>
                <TabControl Grid.Row="1">
                    <TabItem Header="{DynamicResource scenarios.promptSent}">
                        <Grid RowDefinitions="Auto,*">
                            <Border Grid.Row="0"
                                    Margin="0,0,0,8"
                                    Padding="8"
                                    Background="#1A2028"
                                    BorderBrush="#333"
                                    BorderThickness="1"
                                    CornerRadius="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <Button Content="{DynamicResource prompt.copy}" Click="OnCopyPromptClick"/>
                                    <Button Content="{DynamicResource menu.file.save}" Click="OnSavePromptClick"/>
                                </StackPanel>
                            </Border>
                            <TextBox Grid.Row="1"
                                     Text="{Binding SelectedSolution.PromptSnapshot, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="Wrap"
                                     FontFamily="Consolas, Menlo, monospace"
                                     FontSize="12"
                                     Background="Transparent"
                                     BorderThickness="0"/>
                        </Grid>
                    </TabItem>
                    <TabItem Header="{DynamicResource scenarios.artifacts}">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <Button Content="TXT" Click="OnExportTxtClick"/>
                                <Button Content="MD" Click="OnExportMarkdownClick"/>
                                <Button Content="PDF" Click="OnExportPdfClick"/>
                                <Button Content="Word" Click="OnExportWordClick"/>
                                <Button Content="{DynamicResource prompt.copy}" Click="OnCopyFormattedArtifactClick"/>
                            </StackPanel>
                            <TabControl>
                                <TabItem Header="Preview">
                                    <ScrollViewer>
                                        <ItemsControl ItemsSource="{Binding SelectedArtifactMarkdownBlocks}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:MarkdownPreviewViewModel">
                                                    <Border Background="{Binding IsCode, Converter={x:Static BooleanToBrushConverter.Instance}}"
                                                            BorderBrush="#374151"
                                                            BorderThickness="{Binding IsCode, Converter={x:Static BooleanToThicknessConverter.Instance}}"
                                                            CornerRadius="4"
                                                            Padding="{Binding IsCode, Converter={x:Static BooleanToPaddingConverter.Instance}}"
                                                            Margin="{Binding Margin}">
                                                        <TextBlock Text="{Binding Text}"
                                                                   TextWrapping="Wrap"
                                                                   FontSize="{Binding FontSize}"
                                                                   FontWeight="{Binding FontWeight}"
                                                                   Foreground="{Binding Foreground}"
                                                                   FontFamily="{Binding IsCode, Converter={x:Static BooleanToFontFamilyConverter.Instance}}"/>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>
                                </TabItem>
                                <TabItem Header="Raw">
                                    <ItemsControl ItemsSource="{Binding SelectedSolutionArtifacts}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="vm:SolutionArtifactViewModel">
                                                <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,6">
                                                    <StackPanel Spacing="4">
                                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                                            <TextBlock Text="{Binding Label}" FontWeight="SemiBold"/>
                                                            <TextBlock Text="{Binding KindDisplay}" Opacity="0.6" FontSize="11"/>
                                                            <TextBlock Text="{Binding MimeType}" Opacity="0.4" FontSize="11"/>
                                                        </StackPanel>
                                                        <TextBox Text="{Binding InlineContent, Mode=OneWay}"
                                                                 IsReadOnly="True"
                                                                 AcceptsReturn="True"
                                                                 TextWrapping="Wrap"
                                                                 FontFamily="Consolas, Menlo, monospace"
                                                                 FontSize="12"
                                                                 Background="Transparent"
                                                                 BorderThickness="0"
                                                                 MaxHeight="500"/>
                                                    </StackPanel>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </TabItem>
                            </TabControl>
                        </StackPanel>
                    </TabItem>
                </TabControl>
            </Grid>
        </Border>
    </Grid>
</UserControl>
