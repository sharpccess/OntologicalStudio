<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             x:Class="OntologicalStudio.Desktop.Views.UniverseCanvasView"
             x:DataType="vm:UniverseCanvasViewModel">
    <Grid ColumnDefinitions="320,Auto,*" Margin="8">
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,8,0">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource canvas.title}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.zoomOut}" Command="{Binding ZoomOutCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                        <Button Content="{DynamicResource canvas.zoomReset}" Command="{Binding ResetZoomCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                        <Button Content="{DynamicResource canvas.zoomIn}" Command="{Binding ZoomInCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                        <Button Content="{DynamicResource canvas.linkMode}" Command="{Binding ToggleLinkModeCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.createEntity}" FontWeight="SemiBold"/>
                    <TextBox Watermark="{DynamicResource entities.type}"
                             Text="{Binding SelectedEntityTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding HasSelectedUniverse}"/>
                    <TextBox Watermark="{DynamicResource canvas.entityNameOptional}"
                             Text="{Binding NewEntityName, Mode=TwoWay}"
                             IsEnabled="{Binding HasSelectedUniverse}"/>
                    <TextBox Watermark="{DynamicResource canvas.entityDescription}"
                             Text="{Binding NewEntityDescription, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="72"
                             IsEnabled="{Binding HasSelectedUniverse}"/>
                    <TextBlock Text="{DynamicResource canvas.createHint}"
                               Opacity="0.6"
                               FontSize="11"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.connectEntities}" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource canvas.source}" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkSource, Mode=TwoWay}"
                              IsEnabled="{Binding HasSelectedUniverse}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource canvas.relationshipType}" Opacity="0.7" FontSize="11"/>
                    <TextBox Watermark="{DynamicResource canvas.relationshipType}"
                             Text="{Binding SelectedRelationshipTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding HasSelectedUniverse}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ComboBox ItemsSource="{Binding RelationshipTypes}"
                                  SelectedItem="{Binding SelectedRelationshipType, Mode=TwoWay}"
                                  IsEnabled="{Binding HasSelectedUniverse}"
                                  MinWidth="220">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="{DynamicResource relationship.removeTypeFromHistory}"
                                Command="{Binding DeleteActiveRelationshipTypeFromHistoryCommand}"
                                IsEnabled="{Binding HasSelectedUniverse}"/>
                    </StackPanel>
                    <TextBlock Text="{DynamicResource canvas.target}" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkTarget, Mode=TwoWay}"
                              IsEnabled="{Binding HasSelectedUniverse}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{DynamicResource canvas.connect}" Command="{Binding ConnectCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                        <Button Content="{DynamicResource canvas.refresh}" Command="{Binding RefreshCommand}" IsEnabled="{Binding HasSelectedUniverse}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.selectedNode}" FontWeight="SemiBold"/>
                    <TextBox Watermark="{DynamicResource canvas.nodeName}"
                             Text="{Binding SelectedNodeName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Watermark="{DynamicResource entities.type}"
                             Text="{Binding SelectedNodeEntityTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <TextBox Watermark="{DynamicResource canvas.nodeDescription}"
                             Text="{Binding SelectedNodeDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="70"/>
                    <TextBox Watermark="{DynamicResource entities.notes}"
                             Text="{Binding SelectedNodeNotes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             TextWrapping="Wrap"
                             Height="60"/>
                    <TextBlock Text="Color" Opacity="0.7" FontSize="11"/>
                    <ItemsControl ItemsSource="{Binding NodeColorPalette}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Width="22"
                                        Height="22"
                                        Margin="0,0,6,6"
                                        CornerRadius="11"
                                        BorderBrush="#6B7280"
                                        BorderThickness="1"
                                        Background="{Binding Hex}"
                                        Tag="{Binding Hex}"
                                        PointerPressed="OnNodeColorSwatchPressed"/>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <TextBox Watermark="#RRGGBB"
                             Text="{Binding SelectedNodeColor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.saveNode}"
                                Click="OnSaveSelectedNodeClick"/>
                        <Button Content="{DynamicResource canvas.deleteSelectedNode}"
                                Command="{Binding DeleteSelectedNodeCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.selectedRelationship}" FontWeight="SemiBold"/>
                    <TextBox Watermark="{DynamicResource canvas.relationshipType}"
                             Text="{Binding SelectedNodeRelationshipTypeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <ComboBox ItemsSource="{Binding RelationshipTypes}"
                                  SelectedItem="{Binding SelectedNodeRelationshipType, Mode=TwoWay}"
                                  SelectionChanged="OnSelectedRelationshipTypeComboChanged"
                                  MinWidth="220">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <Button Content="{DynamicResource relationship.removeTypeFromHistory}"
                                Command="{Binding DeleteSelectedRelationshipTypeFromHistoryCommand}"/>
                    </StackPanel>
                    <TextBox Watermark="{DynamicResource canvas.relationshipDescription}"
                             Text="{Binding SelectedNodeRelationshipDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True"
                             Height="60"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.saveRelationship}"
                                Click="OnSaveSelectedRelationshipClick"/>
                        <Button Content="{DynamicResource canvas.menu.deleteRelationship}"
                                Click="OnDeleteSelectedRelationshipClick"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <StackPanel DataContext="{Binding Hydration}">
                        <TextBlock Text="{DynamicResource canvas.hydration}" FontWeight="SemiBold"/>
                        <TextBlock Text="{DynamicResource ai.hydrate.mode}" Opacity="0.7" FontSize="11"/>
                        <ComboBox ItemsSource="{Binding HydrationModes}"
                                  SelectedItem="{Binding SelectedHydrationMode, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding DisplayName}"/>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                        <TextBox Watermark="{DynamicResource canvas.customPrompt}"
                                 Text="{Binding CustomPrompt, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="110"/>
                        <Button Content="{DynamicResource entity.hydrate}"
                                Command="{Binding HydrateCurrentNodeCommand}"/>
                        <TextBlock Text="{DynamicResource canvas.providerPrompt}" Opacity="0.7" FontSize="11"/>
                        <TextBox Text="{Binding LastPromptSent}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Height="150"/>
                        <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      Background="#2d3742"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Background="#11151a">
            <ScrollViewer x:Name="CanvasScrollHost"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Border x:Name="CanvasContextSurface"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            Background="Transparent"/>
                    <Canvas x:Name="CanvasHost"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                        </Canvas.RenderTransform>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>