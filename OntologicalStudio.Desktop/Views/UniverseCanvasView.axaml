<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             x:Class="OntologicalStudio.Desktop.Views.UniverseCanvasView"
             x:DataType="vm:UniverseCanvasViewModel">
    <Grid ColumnDefinitions="320,Auto,*" Margin="8">
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,8,0">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="{DynamicResource canvas.title}" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.zoomOut}" Command="{Binding ZoomOutCommand}"/>
                        <Button Content="{DynamicResource canvas.zoomReset}" Command="{Binding ResetZoomCommand}"/>
                        <Button Content="{DynamicResource canvas.zoomIn}" Command="{Binding ZoomInCommand}"/>
                        <Button Content="{DynamicResource canvas.linkMode}" Command="{Binding ToggleLinkModeCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.createEntity}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding EntityTypes}"
                              SelectedItem="{Binding SelectedEntityType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Watermark="{DynamicResource canvas.entityNameOptional}"
                             Text="{Binding NewEntityName, Mode=TwoWay}"/>
                    <TextBox Watermark="{DynamicResource canvas.entityDescription}"
                             Text="{Binding NewEntityDescription, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="72"/>
                    <TextBlock Text="{DynamicResource canvas.createHint}"
                               Opacity="0.6"
                               FontSize="11"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.connectEntities}" FontWeight="SemiBold"/>
                    <TextBlock Text="{DynamicResource canvas.source}" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkSource, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource canvas.relationshipType}" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding RelationshipTypes}"
                              SelectedItem="{Binding SelectedRelationshipType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="{DynamicResource canvas.target}" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkTarget, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="{DynamicResource canvas.connect}" Command="{Binding ConnectCommand}"/>
                        <Button Content="{DynamicResource canvas.refresh}" Command="{Binding RefreshCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.selectedNode}" FontWeight="SemiBold"/>
                    <TextBox Watermark="{DynamicResource canvas.nodeName}"
                             Text="{Binding SelectedNodeName, Mode=TwoWay}"/>
                    <TextBlock Text="{Binding SelectedNode.TypeName}" Opacity="0.7" FontSize="11"/>
                    <TextBox Watermark="{DynamicResource canvas.nodeDescription}"
                             Text="{Binding SelectedNodeDescription, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="70"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.saveNode}"
                                Click="OnSaveSelectedNodeClick"/>
                        <Button Content="{DynamicResource canvas.deleteSelectedNode}"
                                Command="{Binding DeleteSelectedNodeCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="{DynamicResource canvas.selectedRelationship}" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding RelationshipTypes}"
                              SelectedItem="{Binding SelectedNodeRelationshipType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Watermark="{DynamicResource canvas.relationshipDescription}"
                             Text="{Binding SelectedNodeRelationshipDescription, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="60"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource canvas.saveRelationship}"
                                Click="OnSaveSelectedRelationshipClick"/>
                        <Button Content="{DynamicResource canvas.menu.deleteRelationship}"
                                Click="OnDeleteSelectedRelationshipClick"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <StackPanel DataContext="{Binding Hydration}">
                        <TextBlock Text="{DynamicResource canvas.hydration}" FontWeight="SemiBold"/>
                        <TextBox Watermark="{DynamicResource canvas.customPrompt}"
                                 Text="{Binding CustomPrompt, Mode=TwoWay}"
                                 AcceptsReturn="True"
                                 Height="72"/>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Motivations" IsChecked="{Binding IncludeMotivations, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Fears" IsChecked="{Binding IncludeFears, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Incentives" IsChecked="{Binding IncludeIncentives, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Patterns" IsChecked="{Binding IncludeBehavioralPatterns, Mode=TwoWay}" Margin="0,0,8,4"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="{DynamicResource canvas.previewHydration}" Command="{Binding PreviewCommand}"/>
                            <Button Content="{DynamicResource canvas.apply}" Command="{Binding ApplyCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
                        <Expander Header="{DynamicResource canvas.preview}" IsExpanded="True">
                            <StackPanel Spacing="4">
                                <TextBlock Text="{DynamicResource canvas.suggestedProperties}" FontWeight="SemiBold" FontSize="11"/>
                                <TextBox Text="{Binding Preview.Result.SuggestedProperties, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                                <TextBlock Text="{DynamicResource canvas.suggestedNotes}" FontWeight="SemiBold" FontSize="11"/>
                                <TextBox Text="{Binding Preview.Result.SuggestedNotes, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                                <TextBlock Text="{DynamicResource canvas.providerPrompt}" FontWeight="SemiBold" FontSize="11"/>
                                <TextBox Text="{Binding Preview.PromptUsed, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="70"/>
                            </StackPanel>
                        </Expander>
                        <Expander Header="{DynamicResource canvas.diffApply}" IsExpanded="True">
                            <StackPanel Spacing="4">
                                <CheckBox Content="{DynamicResource canvas.applyHydrationData}" IsChecked="{Binding ApplyHydrationData, Mode=TwoWay}"/>
                                <TextBox Text="{Binding DiffHydrationData, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                                <CheckBox Content="{DynamicResource canvas.applyNotes}" IsChecked="{Binding ApplyNotes, Mode=TwoWay}"/>
                                <TextBox Text="{Binding DiffNotes, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                                <CheckBox Content="{DynamicResource canvas.applyConfidence}" IsChecked="{Binding ApplyConfidence, Mode=TwoWay}"/>
                                <CheckBox Content="{DynamicResource canvas.applyCompleteness}" IsChecked="{Binding ApplyCompleteness, Mode=TwoWay}"/>
                                <TextBox Text="{Binding DiffScores, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="60"/>
                            </StackPanel>
                        </Expander>
                        <Expander Header="{DynamicResource canvas.history}">
                            <ItemsControl ItemsSource="{Binding History}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding ProviderUsed}" FontWeight="SemiBold" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <GridSplitter Grid.Column="1"
                      Width="8"
                      Background="#2d3742"
                      ResizeDirection="Columns"
                      ShowsPreview="True"/>

        <Border Grid.Column="2" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Background="#11151a">
            <ScrollViewer x:Name="CanvasScrollHost"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Grid>
                    <Border x:Name="CanvasContextSurface"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            Background="Transparent"/>
                    <Canvas x:Name="CanvasHost"
                            Width="{Binding CanvasWidth}"
                            Height="{Binding CanvasHeight}"
                            RenderTransformOrigin="0,0">
                        <Canvas.RenderTransform>
                            <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                        </Canvas.RenderTransform>
                    </Canvas>
                </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>