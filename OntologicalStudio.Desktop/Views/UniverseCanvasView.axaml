<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:OntologicalStudio.Desktop.ViewModels"
             x:Class="OntologicalStudio.Desktop.Views.UniverseCanvasView"
             x:DataType="vm:UniverseCanvasViewModel">
    <Grid ColumnDefinitions="320,*" Margin="8">
        <Border Grid.Column="0" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Padding="10" Margin="0,0,8,0">
            <ScrollViewer>
                <StackPanel Spacing="8">
                    <TextBlock Text="Universe Canvas" FontWeight="Bold" FontSize="16"/>
                    <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" TextWrapping="Wrap" FontSize="11"/>
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="Zoom -" Command="{Binding ZoomOutCommand}"/>
                        <Button Content="100%" Command="{Binding ResetZoomCommand}"/>
                        <Button Content="Zoom +" Command="{Binding ZoomInCommand}"/>
                        <Button Content="Link mode" Command="{Binding ToggleLinkModeCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="Create entity" FontWeight="SemiBold"/>
                    <ComboBox ItemsSource="{Binding EntityTypes}"
                              SelectedItem="{Binding SelectedEntityType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBox Watermark="Entity name (optional)"
                             Text="{Binding NewEntityName, Mode=TwoWay}"/>
                    <TextBox Watermark="Entity description"
                             Text="{Binding NewEntityDescription, Mode=TwoWay}"
                             AcceptsReturn="True"
                             Height="72"/>
                    <TextBlock Text="Double-click on the canvas to place the entity."
                               Opacity="0.6"
                               FontSize="11"
                               TextWrapping="Wrap"/>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="Connect entities" FontWeight="SemiBold"/>
                    <TextBlock Text="Source" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkSource, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="Relationship type" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding RelationshipTypes}"
                              SelectedItem="{Binding SelectedRelationshipType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <TextBlock Text="Target" Opacity="0.7" FontSize="11"/>
                    <ComboBox ItemsSource="{Binding Nodes}"
                              SelectedItem="{Binding LinkTarget, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Name}"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Button Content="Connect" Command="{Binding ConnectCommand}"/>
                        <Button Content="Refresh" Command="{Binding RefreshCommand}"/>
                    </StackPanel>

                    <Separator Margin="0,4"/>
                    <TextBlock Text="Selected node" FontWeight="SemiBold"/>
                    <TextBlock Text="{Binding SelectedNode.Name}" FontWeight="Bold"/>
                    <TextBlock Text="{Binding SelectedNode.TypeName}" Opacity="0.7" FontSize="11"/>
                    <TextBlock Text="{Binding SelectedNode.Description}" TextWrapping="Wrap" FontSize="11"/>
                    <Button Content="Delete selected node"
                            Command="{Binding DeleteSelectedNodeCommand}"/>

                    <Separator Margin="0,4"/>
                    <StackPanel DataContext="{Binding Hydration}">
                        <TextBlock Text="Hydration" FontWeight="SemiBold"/>
                        <WrapPanel Orientation="Horizontal">
                            <CheckBox Content="Motivations" IsChecked="{Binding IncludeMotivations, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Fears" IsChecked="{Binding IncludeFears, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Incentives" IsChecked="{Binding IncludeIncentives, Mode=TwoWay}" Margin="0,0,8,4"/>
                            <CheckBox Content="Patterns" IsChecked="{Binding IncludeBehavioralPatterns, Mode=TwoWay}" Margin="0,0,8,4"/>
                        </WrapPanel>
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Button Content="Preview hydration" Command="{Binding PreviewCommand}"/>
                            <Button Content="Apply" Command="{Binding ApplyCommand}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding StatusMessage}" Opacity="0.7" FontSize="11" TextWrapping="Wrap"/>
                        <Expander Header="Preview" IsExpanded="True">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Suggested properties" FontWeight="SemiBold" FontSize="11"/>
                                <TextBox Text="{Binding Preview.SuggestedProperties, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                                <TextBlock Text="Suggested notes" FontWeight="SemiBold" FontSize="11"/>
                                <TextBox Text="{Binding Preview.SuggestedNotes, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" Height="90"/>
                            </StackPanel>
                        </Expander>
                        <Expander Header="History">
                            <ItemsControl ItemsSource="{Binding History}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="#333" BorderThickness="0,0,0,1" Padding="0,4">
                                            <StackPanel>
                                                <TextBlock Text="{Binding CreatedAt}" FontSize="11" Opacity="0.7"/>
                                                <TextBlock Text="{Binding ProviderUsed}" FontWeight="SemiBold" FontSize="11"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Border>

        <Border Grid.Column="1" BorderBrush="#444" BorderThickness="1" CornerRadius="4" Background="#11151a">
            <ScrollViewer x:Name="CanvasScrollHost"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <Canvas x:Name="CanvasHost"
                        Width="{Binding CanvasWidth}"
                        Height="{Binding CanvasHeight}"
                        RenderTransformOrigin="0,0">
                    <Canvas.RenderTransform>
                        <ScaleTransform ScaleX="{Binding ZoomScale}" ScaleY="{Binding ZoomScale}"/>
                    </Canvas.RenderTransform>
                </Canvas>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>