{
  "name": "ontologicalstudio-bridge",
  "displayName": "Ontological Studio Bridge",
  "description": "Connects the OntologicalStudio desktop app to VSCode / TRAE: forwards prompts through vscode.lm (Copilot, Claude, etc.) and embeds the Ontological Studio panel.",
  "version": "0.1.0",
  "publisher": "ontologicalstudio",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "ontologicalstudio.startBridge",
        "title": "Ontological Studio: Start AI Bridge",
        "category": "Ontological Studio"
      },
      {
        "command": "ontologicalstudio.stopBridge",
        "title": "Ontological Studio: Stop AI Bridge",
        "category": "Ontological Studio"
      },
      {
        "command": "ontologicalstudio.showStatus",
        "title": "Ontological Studio: Show Bridge Status",
        "category": "Ontological Studio"
      },
      {
        "command": "ontologicalstudio.openPanel",
        "title": "Ontological Studio: Open Panel",
        "category": "Ontological Studio"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "ontologicalstudio",
          "title": "Ontological Studio",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "ontologicalstudio": [
        {
          "id": "ontologicalstudio.statusView",
          "name": "Bridge Status",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Ontological Studio Bridge",
      "properties": {
        "ontologicalstudio.bridge.port": {
          "type": "number",
          "default": 39217,
          "description": "Local HTTP port for the AI bridge (must match the value configured in the desktop app)."
        },
        "ontologicalstudio.bridge.autoStart": {
          "type": "boolean",
          "default": true,
          "description": "Start the bridge automatically when VSCode/TRAE launches."
        },
        "ontologicalstudio.bridge.preferredModel": {
          "type": "string",
          "default": "",
          "description": "Optional: preferred vscode.lm model id (e.g. 'copilot-gpt-4o'). Empty = auto-pick first available."
        },
        "ontologicalstudio.desktop.apiBaseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:53821",
          "description": "Base URL of the Ontological Studio desktop API."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.95.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "^5.4.0"
  }
}
